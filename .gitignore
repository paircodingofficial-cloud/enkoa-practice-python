# ══════════════════════════════════════════════════════════
#  내 작업물 — 커밋되지 않습니다
#  실습은 전부 '내작업/' 안에서 하세요.
# ══════════════════════════════════════════════════════════
내작업/*
!내작업/README.md
.백업/

# ── 파이썬 가상환경 ────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── 파이썬 자동 생성물 ─────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ── 주피터 ────────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
.virtual_documents/

# ── 노트북 실행 산출물 ─────────────────────────────────────
output/

# ── 비밀 정보 (API 키 등 — 절대 커밋 금지) ──────────────────
.env
.env.*
*.key
*.pem
secrets.json

# ── 에디터 · IDE ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── AI 코딩 도구가 만드는 상태 폴더 ─────────────────────────
.omc/
.claude/
.cursor/
.aider*
.codex/

# ── 운영체제 ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini
